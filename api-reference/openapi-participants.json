                          "delta": {}
                        },
                        "duration_insights": {
                          "thresholds": { "p25": 543.0, "p75": 609.0 },
                          "short": { "count": 2, "avg_score": 59.4 },
                          "medium": { "count": 1, "avg_score": 65.0 },
                          "long": { "count": 2, "avg_score": 47.5 }
                        },
                        "trend": {
                          "direction": "insufficient_data",
