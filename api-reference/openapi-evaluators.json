                        "id": "a2b542de-a06a-44ea-9975-20cab95ccaa8",
                        "name": "Verificación de Identidad",
                        "description": "El agente debe verificar la identidad del cliente solicitando al menos dos datos personales.",
                        "type": "strict",
                        "weight": 0
                      },
