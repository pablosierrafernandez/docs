{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Heify Docs",
  "api": {
    "mdx": {
      "server": "https://tu-dominio-api.com/api/v1",
      "auth": {
        "method": "key",
        "name": "x-api-key"
      }
    },
    "playground": {
      "display": "interactive"
    }
  },
  "colors": {
    "primary": "#3B82F6",
    "light": "#60A5FA",
    "dark": "#2563EB"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "core/objects",
              "core/errors",
              "core/limits"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "code",
        "groups": [
          {
            "group": "Configuration Endpoints",
            "icon": "gear",
            "pages": [
              "api-reference/configuration/create",
              "api-reference/configuration/get",
              "api-reference/configuration/delete"
            ]
          },
          {
            "group": "Transcription Endpoints",
            "icon": "microphone",
            "pages": [
              {
                "group": "Submit Transcription",
              "tag": "2",
                "pages": [
                  "api-reference/transcription/submit",
                  "api-reference/transcription/request-upload-url"
                  
                ]
              },
              "api-reference/transcription/details",
              "api-reference/transcription/delete",
              "api-reference/transcription/update-group"
            ]
          }
        ]
      },
      {
        "tab": "Sandbox",
        "icon": "flask",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "sandbox/index",
              "sandbox/authentication"
            ]
          },
          {
            "group": "Platform Features",
            "pages": [
              "sandbox/api-keys",
              "sandbox/configurations",
              "sandbox/transcribe",
              "sandbox/transcriptions",
              "sandbox/analytics"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://sandbox.heify.com",
          "icon": "chart-line"
        },
        {
          "anchor": "Support",
          "href": "https://www.heify.com/contact.html",
          "icon": "headset"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "https://www.heify.com/contact.html"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://sandbox.heify.com/sandbox/api-keys"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/heify"
    }
  }
}