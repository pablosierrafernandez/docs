{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Heify Docs",
  "api": {
    "openapi": [
      "api-reference/openapi-configurations.json",
      "api-reference/openapi-transcriptions.json",
      "api-reference/openapi-evaluators.json",
      "api-reference/openapi-participants.json"
    ],
    "mdx": {
      "server": "https://api.heify.com",
      "auth": {
        "method": "key",
        "name": "x-api-key"
      }
    },
    "playground": {
      "display": "interactive"
    }
  },
  "colors": {
    "primary": "#3B82F6",
    "light": "#60A5FA",
    "dark": "#2563EB"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core Objects",
            "pages": [
              {
                "group": "Modules",
                "icon": "layer-group",
                "pages": [
                  "core/configuration",
                  "core/evaluator",
                  "core/participant"
                ]
              },
              "core/transcription"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/rate-limits",
              "platform/errors"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "code",
        "groups": [
          {
            "group": "Configurations",
            "icon": "gear",
            "pages": [
              "api-reference/configuration/create",
              "api-reference/configuration/get",
              "api-reference/configuration/list",
              "api-reference/configuration/update",
              "api-reference/configuration/delete",
              "api-reference/configuration/analytics"
            ]
          },
          {
            "group": "Evaluators",
            "icon": "clipboard-check",
            "pages": [
              "api-reference/evaluator/create",
              "api-reference/evaluator/get",
              "api-reference/evaluator/list",
              "api-reference/evaluator/update",
              "api-reference/evaluator/delete",
              "api-reference/evaluator/analytics"
            ]
          },
          {
            "group": "Participants",
            "icon": "user",
            "pages": [
              "api-reference/participant/create",
              "api-reference/participant/list",
              "api-reference/participant/update",
              "api-reference/participant/delete",
              "api-reference/participant/analytics"
            ]
          },
          {
            "group": "Transcriptions",
            "icon": "microphone",
            "pages": [
              "api-reference/transcription/submit",
              "api-reference/transcription/request-upload-url",
              "api-reference/transcription/details",
              "api-reference/transcription/list",
              "api-reference/transcription/update-group",
              "api-reference/transcription/delete"
            ]
          }
        ]
      },
      {
        "tab": "Sandbox",
        "icon": "flask",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "sandbox/index",
              "sandbox/authentication",
              "sandbox/api-keys"
            ]
          },
          {
            "group": "Modules",
            "pages": [
              "sandbox/configurations",
              "sandbox/evaluators",
              "sandbox/participants"
            ]
          },
          {
            "group": "Transcriptions",
            "pages": [
              "sandbox/transcribe",
              "sandbox/transcriptions"
            ]
          },
          {
            "group": "Analysis",
            "pages": [
              "sandbox/analytics",
              "sandbox/analytics-evaluator",
              "sandbox/analytics-participant"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://sandbox.heify.com",
          "icon": "chart-line"
        },
        {
          "anchor": "Support",
          "href": "https://www.heify.com/contact.html",
          "icon": "headset"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "https://www.heify.com/contact.html"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://sandbox.heify.com/sandbox/api-keys"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/heify"
    }
  }
}
